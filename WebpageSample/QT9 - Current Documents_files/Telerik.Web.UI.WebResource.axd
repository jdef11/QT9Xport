/* RadGrid Filter Drop - List*/
.rcbSlide {
    z-index: 2147483647 !important;
}

.rcbScroll .rcbList {
    position: relative;
    z-index: 2147483647 !important;
}

/* RadButton Skin Change */
.rbSkinnedButton, .rbSkinnedButton:hover {
    border-radius: 3px !important;
}

/* Home Page Tabs */
.RadTabStrip_Metro .rtsLevel1 .rtsSelected .rtsLink {
    border-color: #0057c0 !important;
    background-color: #0057c0 !important;
}

.RadTabStrip_Metro .rtsLevel1 {
    border-color: #0057c0 !important;
}

