	.divCellRow
		{
			float:left; 
			padding:3px;
			margin-right:10px;
		}
		
		.divCellRowDivider
		{
			height:3px;
			clear:both;
		}
		
		.ContentBox
		{
			border:0px outset #dcdcdc;
			background-color:#f5f5f5; 
			opacity:.8; 
			padding:10px; 
			padding:10px; 
			border-radius:0px;
			min-height:475px;
			/* per max st #5613 notes - no background image on content box
			background-image: url('/common/QT9Logo450-0.png'); 
			background-repeat:no-repeat; 
			background-position:center center; 
			background-attachment:fixed;
			*/
		}
		
		.ContentBoxHeader
		{
    
			/* CSS Gradient */
			background: #f5f5f5;
			
			color:#202020;
			padding:5px; 
			border-radius:0px; 
			margin-bottom:10px;
		}
		
		.ContentBox div.RadGrid_WebBlue
		{
			opacity:	1.0;
		}
		
		.TabMultiPage
		{
			width:98%;
			background-color:#FFFFFF;
			padding:10px;  
			border:1px outset #dcdcdc; 
			border-radius:0px; 
			min-height:100px;
		}
		
		
				
		.RadMenu_Context
		{
			z-index: 2147483647 !important;
		}

        .col1h, .col2h, .col3h, .col4h
        {
            width: 110px;
            display: inline-block;
       
		 }  
        
        .RadComboBoxTest
        {
            vertical-align: middle;
            float: left;
            margin: 0;
            padding: 0 5px 0 0;
            line-height: 9px;
        }                      
